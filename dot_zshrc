# devbox: skip PATH replacement to preserve commonenv's priority order
eval "$(devbox global shellenv | grep -v '^export PATH=')"
eval "$(mise activate zsh)"

autoload -Uz colors && colors

# Sheldon plugin manager
eval "$(sheldon source)"

# Completion settings
# ref: https://gist.github.com/ctechols/ca1035271ad134841284#gistcomment-2308206
autoload -Uz compinit
for dump in ~/.zcompdump(N.mh+24); do
  compinit
done
compinit -C

zstyle ':completion:*' matcher-list '' 'm:{a-zA-Z}={A-Za-z} r:|[-_.]=**'
zstyle ':completion:*' matcher-list '' 'm:{a-z}={A-Z}' '+m:{A-Z}={a-z}'

eval "$(starship init zsh)"

# History
HISTFILE=$HOME/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt share_history

# Typo correction
setopt correct

SPROMPT="もしかして %B%r%b かな？ [%{${fg[green]}%}そう(y)%{${reset_color}%},%{${fg[red]}%}違うよ(n)%{${reset_color}%},%{${fg[blue]}%}やーめた(a)%{${reset_color}%},%{${fg[cyan]}%}直すね(e)%{${reset_color}%}]: "

# 1Password treats each new shell session as a fresh biometric session, so a
# personal-account op read re-prompts on every new terminal/agent invocation
# even within minutes. Route through the "Service Account Auth Token: CLI
# automation" item's Service Account token instead, which reads without a
# biometric prompt. The token itself is cached in /private/tmp (mode 600,
# 8h TTL) so it survives across shell sessions until 1Password's own lock
# state or the TTL catches up with it.
__op_service_account_token() {
  local cache="/private/tmp/.op-sa-token-$UID"
  local ttl=28800 # 8 hours

  if [[ -f "$cache" ]]; then
    local age=$(( $(date +%s) - $(stat -f %m "$cache" 2>/dev/null || echo 0) ))
    (( age < ttl )) && { cat "$cache"; return }
  fi

  local sa_token
  sa_token=$(op read "op://Development/yaftsrqjifcjeoyertvtwqm2yy/credential") || return
  [[ -n "$sa_token" ]] || return
  ( umask 077; print -r -- "$sa_token" > "$cache" )
  print -r -- "$sa_token"
}

# GitHub Packages auth token from 1Password (the single source of truth).
# Resolved lazily on the first npm/pnpm/bun call so the 1Password prompt appears
# only when a package manager actually runs, then exported for the rest of the
# shell session so later commands and child processes (git hooks, npx) inherit it
# without re-prompting.
__ensure_npm_auth_token() {
  [[ -n "$NPM_AUTH_TOKEN" ]] && return
  local sa_token
  sa_token=$(__op_service_account_token) || return
  [[ -n "$sa_token" ]] || return
  local token
  token=$(OP_SERVICE_ACCOUNT_TOKEN="$sa_token" op read "op://Development/.npmrc/password") || return
  [[ -n "$token" ]] || return
  export NPM_AUTH_TOKEN="$token"
}
npm()  { __ensure_npm_auth_token; command npm "$@" }
npx()  { __ensure_npm_auth_token; command npx "$@" }
pnpm() { __ensure_npm_auth_token; command pnpm "$@" }
bun()  { __ensure_npm_auth_token; command bun "$@" }

# Aliases
alias c="cursor"
alias e="code"
alias g="git"
alias h="hx"
alias t="tmux"

# Force non-blinking bar cursor on each prompt
# Ghostty's cursor-style-blink=false only sets the initial state;
# applications can override it via DECSCUSR escape sequences.
zle-line-init() { printf '\e[6 q' }
zle -N zle-line-init

# ghq + fzf: select repository and cd into it
gf() {
  local repo=$(ghq list | fzf)
  if [ -n "$repo" ]; then
    cd "$(ghq root)/$repo"
  fi
}

# Key bindings for history navigation
# up-line-or-search: filters history by current input, or navigates normally if empty
bindkey '^P' up-line-or-search
bindkey '^N' down-line-or-search

# Google Cloud
if [ -f "${XDG_BIN_HOME}/google-cloud-sdk/path.zsh.inc" ]; then . "${XDG_BIN_HOME}/google-cloud-sdk/path.zsh.inc"; fi
if [ -f "${XDG_BIN_HOME}/google-cloud-sdk/completion.zsh.inc" ]; then . "${XDG_BIN_HOME}/google-cloud-sdk/completion.zsh.inc"; fi
