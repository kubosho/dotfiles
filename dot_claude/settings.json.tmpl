{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "JJ_EDITOR": "false"
  },
  "attribution": {
    "commit": "🤖 Generated with Claude Code\n\nCo-Authored-By: Claude <noreply@anthropic.com>",
    "pr": "🤖 Generated with Claude Code"
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Glob",
      "Grep",
      "Read",
      "Bash(~/.agents/scripts/spec-scope-check.sh:*)",
      "Bash(cat:*)",
      "Bash(chezmoi *)",
      "Bash(echo:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(jj bookmark:*)",
      "Bash(jj config:*)",
      "Bash(jj describe:*)",
      "Bash(jj diff:*)",
      "Bash(jj evolog:*)",
      "Bash(jj file list:*)",
      "Bash(jj file show:*)",
      "Bash(jj help:*)",
      "Bash(jj interdiff:*)",
      "Bash(jj log:*)",
      "Bash(jj new:*)",
      "Bash(jj op log:*)",
      "Bash(jj root:*)",
      "Bash(jj show:*)",
      "Bash(jj status:*)",
      "Bash(jj version:*)",
      "WebFetch(domain:caniuse.com)",
      "WebFetch(domain:dev.to)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:qiita.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:zenn.dev)"
    ],
    "deny": [
      "NotebookEdit",
      "Bash(dotenvx get)",
      "Bash(git clean:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(git gc:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git rm:*)",
      "Bash(jj file untrack:*)",
      "Bash(jj git push:*)",
      "Bash(npm publish)",
      "Bash(op read)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/jj-session-start.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/vcs-overview-session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/jj-pre-tool-use.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/git-prefer-jj.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/jj-pre-edit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/jj-post-tool-use.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/jj-stop-check.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a'"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/jj-worktree-create.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/jj-worktree-remove.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
{{- if ne .chezmoi.hostname "local" }}
  "deniedMcpServers": [
    { "serverUrl": "https://mcp.atlassian.com/*" }
  ],
{{- end }}
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "chrome-devtools-mcp@chrome-devtools-plugins": true,
    "dig@kuu-marketplace": true,
    "anti-slop-code@kubosho-skills": true,
    "baseline@kubosho-skills": true,
    "pr-description@kubosho-skills": true,
    "test-principles@kubosho-skills": true,
    "skill-creator@claude-plugins-official": true,
    "codex@openai-codex": true,
    "figma@claude-plugins-official": true,
    "a11y-specialist-skills@a11y-specialist-skills": true,
    "security-guidance@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "kuu-marketplace": {
      "source": {
        "source": "github",
        "repo": "fumiya-kume/claude-code"
      }
    },
    "kubosho-skills": {
      "source": {
        "source": "github",
        "repo": "kubosho/my-skills"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "a11y-specialist-skills": {
      "source": {
        "source": "github",
        "repo": "masuP9/a11y-specialist-skills"
      }
    }
  },
  "outputStyle": "お嬢様",
  "language": "日本語",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "api.github.com",
        "github.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "nodejs.org",
        "dev.to",
        "qiita.com",
        "zenn.dev"
      ]
    },
    "excludedCommands": [
      "chezmoi apply:*",
      "gh pr checks:*",
      "gh pr close:*",
      "gh pr diff:*",
      "gh pr list:*",
      "gh pr status:*",
      "gh pr view:*",
      "git commit:*",
      "herdr:*",
      "jj:*",
      "mani:*"
    ]
  },
  "autoUpdatesChannel": "latest",
  "skipAutoPermissionPrompt": true
}
